# Starbase MCP — environment configuration
#
# You normally do NOT need this file. Run `npx @egmer/starbase-mcp login` once
# and your token is saved to ~/.starbase-mcp/config.json automatically.
#
# Use env vars only if you prefer not to save a config file (e.g. you want to put
# the token directly in your Claude MCP server config under "env").

# REQUIRED: your Starbase refresh token. Copy the value of the localStorage key
# starting with "sb-" and ending in "-auth-token" from starbaseos.com (you can
# paste the whole value — the server extracts the refresh token). The server
# auto-refreshes it from then on; you should never have to re-paste.
STARBASE_REFRESH_TOKEN=

# OPTIONAL: only set these if Starbase ever changes its Supabase project.
# Sensible defaults for the shared Starbase OS project are baked in.
# STARBASE_SUPABASE_URL=https://lophwbygnmaqqutdycsu.supabase.co
# STARBASE_SUPABASE_ANON_KEY=
